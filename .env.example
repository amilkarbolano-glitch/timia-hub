# ============================================
# Timia Hub — Variables de entorno
# Copia este archivo como .env.local
# ============================================

# Base de datos
# SQLite local (desarrollo):
DATABASE_URL="file:./timia.db"
# PostgreSQL producción (Railway / AWS RDS):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/timia_hub?schema=public"

# Servidor Express
PORT=4000
FRONTEND_URL="http://localhost:3000"

# Cliente React (Vite)
VITE_API_URL="http://localhost:4000"

# Gemini AI (de AI Studio)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
